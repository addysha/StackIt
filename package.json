{
  "name": "stackit",
  "version": "0.1.0",
  "private": true,
  "description": "Personal business assistant for small business owners.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "worker:dev": "tsx watch src/server/index.ts",
    "worker:start": "tsx src/server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\"",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "keywords": [
    "nextjs",
    "dashboard",
    "shopify",
    "akahu",
    "business-assistant"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/animejs": "^3.1.13",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.72.0"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@clerk/themes": "^2.4.57",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.42.0",
    "@tanstack/react-query": "^5.90.21",
    "animejs": "^4.3.6",
    "bullmq": "^5.70.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-js": "^1.359.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "^7.71.2",
    "react-resizable": "^3.1.3",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
